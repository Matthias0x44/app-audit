    "receipt", "invoice", "subscription", "renews", "renewed", "payment received",
    "your plan", "auto-renew", "another month", "has been charged", "billing"
  ],
  "recurrence_keywords": [
    "monthly", "renews", "renewed", "another month", "subscription",
    "recurring", "/month", "per month", "annually", "yearly", "/year", "annual"
  ],
  "yearly_keywords": ["annually", "yearly", "/year", "per year", "annual plan"]
