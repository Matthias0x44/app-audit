{
  "_meta": {
    "note": "Rules for classifying receipt emails. Aggregators (Apple/Stripe/PayPal) bill on behalf of other merchants, so the real service name lives in the subject or body, not the sender. Merchants bill directly. Ignore-list senders are recurring non-subscriptions (rides, food, transfers, newsletters)."
  },
  "aggregators": {
    "email.apple.com": { "name": "Apple", "via": "App Store", "merchant_from": "apple_body" },
    "stripe.com": { "name": "Stripe", "via": "Stripe", "merchant_from": "subject_from" },
    "paypal.co.uk": { "name": "PayPal", "via": "PayPal", "merchant_from": "subject_to" },
    "paypal.com": { "name": "PayPal", "via": "PayPal", "merchant_from": "subject_to" },
    "google.com": { "name": "Google Play", "via": "Google Play", "merchant_from": "body_google" }
  },
  "merchants": {
    "smarty.co.uk": { "name": "SMARTY", "category": "Mobile" },
    "vercel.com": { "name": "Vercel", "category": "Developer" },
    "spotify.com": { "name": "Spotify", "category": "Music" },
    "netflix.com": { "name": "Netflix", "category": "Streaming" },
    "openai.com": { "name": "OpenAI", "category": "AI" },
    "anthropic.com": { "name": "Anthropic", "category": "AI" },
    "github.com": { "name": "GitHub", "category": "Developer" },
    "notion.so": { "name": "Notion", "category": "Productivity" },
    "dropbox.com": { "name": "Dropbox", "category": "Storage" },
    "adobe.com": { "name": "Adobe", "category": "Creative" },
    "disneyplus.com": { "name": "Disney+", "category": "Streaming" },
    "nordvpn.com": { "name": "NordVPN", "category": "VPN" },
